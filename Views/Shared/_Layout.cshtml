<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Stacks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg:       #0a0c10;
            --surface:  #111318;
            --panel:    #181c24;
            --border:   #1f2535;
            --accent:   #00e5a0;
            --accent2:  #00bfff;
            --warn:     #ffb930;
            --danger:   #ff4d6d;
            --text:     #eef0f6;
            --sub:      #7b85a0;
            --mono:     'DM Mono', monospace;
            --head:     'Syne', sans-serif;
            --body:     'DM Sans', sans-serif;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--body);
            font-size: 15px;
            min-height: 100vh;
        }

        /* ── TOPBAR ────────────────────────────── */
        .topbar {
            position: sticky; top: 0; z-index: 200;
            background: rgba(10,12,16,0.9);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: stretch;
            height: 56px; padding: 0 2rem;
        }
        .topbar-brand {
            display: flex; align-items: center; gap: 10px;
            font-family: var(--head); font-size: 1.35rem; font-weight: 800;
            color: var(--text); text-decoration: none;
            letter-spacing: -0.5px; margin-right: 2.5rem;
        }
        .topbar-brand .dot { color: var(--accent); }
        .topbar-brand .icon {
            width: 30px; height: 30px; background: var(--accent);
            border-radius: 7px; display: flex; align-items: center; justify-content: center;
        }
        .topbar-brand .icon svg { width: 16px; height: 16px; fill: #000; }
        .topnav { display: flex; align-items: stretch; gap: 2px; }
        .topnav a {
            display: flex; align-items: center; gap: 7px;
            padding: 0 16px;
            font-size: 0.82rem; font-weight: 500; font-family: var(--mono);
            color: var(--sub); text-decoration: none;
            border-bottom: 2px solid transparent;
            transition: color .15s, border-color .15s;
            letter-spacing: 0.02em;
        }
        .topnav a:hover { color: var(--text); }
        .topnav a.active { color: var(--accent); border-bottom-color: var(--accent); }
        .topnav a svg { width: 15px; height: 15px; opacity: 0.7; }
        .topbar-right {
            margin-left: auto; display: flex; align-items: center; gap: 1rem;
        }
        .status-pill {
            font-family: var(--mono); font-size: 0.72rem;
            background: rgba(0,229,160,0.1); color: var(--accent);
            border: 1px solid rgba(0,229,160,0.25);
            border-radius: 20px; padding: 3px 11px;
            letter-spacing: 0.05em;
        }

        /* ── PAGE SHELL ─────────────────────────── */
        .page { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }

        /* ── PAGE HEADER ────────────────────────── */
        .pg-header {
            display: flex; align-items: flex-end; justify-content: space-between;
            margin-bottom: 2.5rem; padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
        }
        .pg-header-left {}
        .pg-eyebrow {
            font-family: var(--mono); font-size: 0.7rem; font-weight: 500;
            color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase;
            margin-bottom: 4px;
        }
        .pg-title {
            font-family: var(--head); font-size: 2rem; font-weight: 800;
            color: var(--text); line-height: 1; letter-spacing: -1px;
        }
        .pg-sub {
            font-size: 0.85rem; color: var(--sub); margin-top: 6px;
        }

        /* ── BUTTONS ────────────────────────────── */
        .btn-primary-custom {
            display: inline-flex; align-items: center; gap: 7px;
            background: var(--accent); color: #000;
            font-family: var(--mono); font-size: 0.78rem; font-weight: 500;
            border: none; border-radius: 8px; padding: 9px 18px;
            cursor: pointer; text-decoration: none; transition: opacity .15s, transform .1s;
            letter-spacing: 0.02em;
        }
        .btn-primary-custom:hover { opacity: 0.88; color: #000; transform: translateY(-1px); }
        .btn-ghost-custom {
            display: inline-flex; align-items: center; gap: 7px;
            background: transparent; color: var(--sub);
            font-family: var(--mono); font-size: 0.78rem; font-weight: 500;
            border: 1px solid var(--border); border-radius: 8px; padding: 8px 18px;
            cursor: pointer; text-decoration: none; transition: all .15s;
            letter-spacing: 0.02em;
        }
        .btn-ghost-custom:hover { border-color: var(--sub); color: var(--text); }
        .btn-back {
            display: inline-flex; align-items: center; gap: 6px;
            color: var(--sub); font-family: var(--mono); font-size: 0.78rem;
            text-decoration: none; padding: 6px 0; transition: color .15s;
            border: none; background: none; cursor: pointer; letter-spacing: 0.02em;
        }
        .btn-back:hover { color: var(--text); }
        .btn-back svg { width: 14px; height: 14px; }

        /* Icon action buttons in tables */
        .tbl-action {
            width: 30px; height: 30px; border-radius: 6px;
            display: inline-flex; align-items: center; justify-content: center;
            border: 1px solid var(--border); background: transparent;
            color: var(--sub); text-decoration: none; transition: all .15s; cursor: pointer;
        }
        .tbl-action:hover { background: var(--panel); color: var(--text); border-color: var(--sub); }
        .tbl-action.danger:hover { border-color: var(--danger); color: var(--danger); background: rgba(255,77,109,0.08); }
        .tbl-action svg { width: 13px; height: 13px; }

        /* ── CARDS ──────────────────────────────── */
        .card-custom {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px; overflow: hidden;
        }
        .card-custom-body { padding: 2rem; }

        /* ── TABLE ──────────────────────────────── */
        .stacks-table { width: 100%; border-collapse: collapse; }
        .stacks-table thead tr {
            border-bottom: 1px solid var(--border);
        }
        .stacks-table thead th {
            font-family: var(--mono); font-size: 0.68rem; font-weight: 500;
            color: var(--sub); text-transform: uppercase; letter-spacing: 0.1em;
            padding: 12px 16px; text-align: left; white-space: nowrap;
        }
        .stacks-table thead th:first-child { padding-left: 24px; }
        .stacks-table thead th:last-child { padding-right: 24px; text-align: right; }
        .stacks-table tbody tr {
            border-bottom: 1px solid rgba(31,37,53,0.6);
            transition: background .12s;
        }
        .stacks-table tbody tr:last-child { border-bottom: none; }
        .stacks-table tbody tr:hover { background: var(--panel); }
        .stacks-table td {
            padding: 14px 16px; color: var(--text); font-size: 0.9rem;
            vertical-align: middle;
        }
        .stacks-table td:first-child { padding-left: 24px; }
        .stacks-table td:last-child { padding-right: 24px; text-align: right; }
        .td-id {
            font-family: var(--mono); font-size: 0.78rem; color: var(--sub);
        }
        .td-main { font-weight: 500; color: var(--text); }
        .td-sub { color: var(--sub); font-size: 0.88rem; }

        /* ── BADGES ─────────────────────────────── */
        .badge-ok {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(0,229,160,0.1); color: var(--accent);
            border: 1px solid rgba(0,229,160,0.2);
            font-family: var(--mono); font-size: 0.7rem; font-weight: 500;
            padding: 3px 10px; border-radius: 20px; letter-spacing: 0.04em;
        }
        .badge-no {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(255,77,109,0.1); color: var(--danger);
            border: 1px solid rgba(255,77,109,0.2);
            font-family: var(--mono); font-size: 0.7rem; font-weight: 500;
            padding: 3px 10px; border-radius: 20px; letter-spacing: 0.04em;
        }
        .badge-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

        /* ── ALERTS ─────────────────────────────── */
        .alert-success-custom {
            background: rgba(0,229,160,0.07); border: 1px solid rgba(0,229,160,0.25);
            border-left: 3px solid var(--accent); border-radius: 10px;
            padding: 12px 16px; margin-bottom: 1.5rem;
            font-size: 0.875rem; color: var(--accent);
            display: flex; align-items: center; gap: 10px;
        }
        .alert-error-custom {
            background: rgba(255,77,109,0.07); border: 1px solid rgba(255,77,109,0.25);
            border-left: 3px solid var(--danger); border-radius: 10px;
            padding: 12px 16px; margin-bottom: 1.5rem;
            font-size: 0.875rem; color: #ff8fa3;
            display: flex; align-items: center; gap: 10px;
        }

        /* ── FORMS ──────────────────────────────── */
        .form-grid { display: flex; flex-direction: column; gap: 1.25rem; }
        .field-group { display: flex; flex-direction: column; gap: 6px; }
        .field-label {
            font-family: var(--mono); font-size: 0.72rem; font-weight: 500;
            color: var(--sub); text-transform: uppercase; letter-spacing: 0.1em;
        }
        .field-input {
            background: var(--panel); border: 1px solid var(--border);
            border-radius: 8px; padding: 10px 14px;
            color: var(--text); font-family: var(--body); font-size: 0.9rem;
            width: 100%; transition: border-color .15s, box-shadow .15s;
            outline: none;
        }
        .field-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(0,229,160,0.12);
        }
        .field-input::placeholder { color: var(--sub); opacity: 0.7; }
        select.field-input option { background: var(--panel); color: var(--text); }
        .form-actions { display: flex; gap: 10px; padding-top: 0.75rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }

        /* ── DETAIL GRID ────────────────────────── */
        .detail-grid {
            display: grid; grid-template-columns: 140px 1fr;
            gap: 0;
        }
        .detail-grid .dk {
            font-family: var(--mono); font-size: 0.72rem; font-weight: 500;
            color: var(--sub); text-transform: uppercase; letter-spacing: 0.08em;
            padding: 14px 0; border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
        }
        .detail-grid .dv {
            font-size: 0.92rem; color: var(--text);
            padding: 14px 0; border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
        }
        .detail-grid .dk:last-of-type,
        .detail-grid .dv:last-of-type { border-bottom: none; }

        /* ── FOOTER ─────────────────────────────── */
        footer {
            border-top: 1px solid var(--border);
            padding: 1.25rem 2rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        footer span {
            font-family: var(--mono); font-size: 0.72rem; color: var(--sub);
            letter-spacing: 0.05em;
        }
        .footer-logo {
            font-family: var(--head); font-weight: 800; font-size: 0.9rem;
            color: var(--sub); letter-spacing: -0.5px;
        }
        .footer-logo span { color: var(--accent); }
    </style>
</head>
<body>

<nav class="topbar">
    <a class="topbar-brand" asp-controller="Home" asp-action="Index">
        <div class="icon">
            <svg viewBox="0 0 16 16"><path d="M2 2h5v12H2zM9 2h5v12H9z"/></svg>
        </div>
        Stacks<span class="dot">.</span>
    </a>
    <div class="topnav">
        <a asp-controller="Home" asp-action="Index">
            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 1L1 7h2v7h4v-4h2v4h4V7h2z"/></svg>
            Overview
        </a>
        <a asp-controller="User" asp-action="Index">
            <svg viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
            Members
        </a>
        <a asp-controller="Book" asp-action="Index">
            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2h8a1 1 0 011 1v10a1 1 0 01-1 1H3a1 1 0 01-1-1V3a1 1 0 011-1zm1 2v8h6V4z"/></svg>
            Catalog
        </a>
        <a asp-controller="Loan" asp-action="Index">
            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M1 8h14M8 1l7 7-7 7"/></svg>
            Loans
        </a>
    </div>
    <div class="topbar-right">
        <span class="status-pill">● live</span>
    </div>
</nav>

<div class="page">
    @RenderBody()
</div>

<footer>
    <div class="footer-logo">Stacks<span>.</span></div>
    <span>Library Management System &mdash; &copy; 2026</span>
    <span>v1.0.0</span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>