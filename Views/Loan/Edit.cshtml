@model LibrarySystem.Models.Loan
@{ ViewData["Title"] = "Edit Loan"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="Loan" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Loans
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow" style="color:#ffb930;">03 — Loans</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Edit loan<br/>record.</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">
            Reassign the member or book for this lending record.
        </p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <form asp-action="Update" asp-controller="Loan" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="form-grid">
                    <div class="field-group">
                        <label asp-for="UserId" class="field-label">Member</label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="field-input"></select>
                    </div>
                    <div class="field-group">
                        <label asp-for="BookId" class="field-label">Book</label>
                        <select asp-for="BookId" asp-items="ViewBag.Books" class="field-input"></select>
                    </div>
                    <div class="form-actions">
                        <button class="btn-primary-custom">Save changes</button>
                        <a asp-action="Index" asp-controller="Loan" class="btn-ghost-custom">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>