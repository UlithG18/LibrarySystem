@model LibrarySystem.Models.Loan

@{
    ViewData["Title"] = "Editar Préstamo";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="Loan" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-pencil me-2" style="color:#fbbf24;"></i>Editar préstamo</h4>
        <small style="color:var(--muted);">Modifica los datos del préstamo registrado</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Update" asp-controller="Loan" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label">Usuario</label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="BookId" class="form-label">Libro</label>
                        <select asp-for="BookId" asp-items="ViewBag.Books" class="form-select"></select>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Actualizar
                        </button>
                        <a asp-action="Index" asp-controller="Loan" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>