@model LibrarySystem.Models.Loan
@{ ViewData["Title"] = "New Loan"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="Loan" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Loans
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow" style="color:#ffb930;">03 — Loans</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Issue a new<br/>loan.</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">
            Assign a book to a library member. Only available books can be selected.
        </p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <form asp-action="Store" asp-controller="Loan" method="post">
                <div class="form-grid">
                    <div class="field-group">
                        <label asp-for="UserId" class="field-label">Member</label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="field-input">
                            <option value="">— Select a member —</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label asp-for="BookId" class="field-label">Book</label>
                        <select asp-for="BookId" asp-items="ViewBag.Books" class="field-input">
                            <option value="">— Select a book —</option>
                        </select>
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert-error-custom">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2L1 14h14zM8 6v4M8 12v1"/></svg>
                            @TempData["message"]
                        </div>
                    }

                    <div class="form-actions">
                        <button type="submit" class="btn-primary-custom">Confirm loan</button>
                        <a asp-action="Index" asp-controller="Loan" class="btn-ghost-custom">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>