@model LibrarySystem.Models.Loan

@{
    ViewData["Title"] = "Nuevo Préstamo";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="Loan" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-plus-circle me-2" style="color:var(--accent);"></i>Registrar préstamo</h4>
        <small style="color:var(--muted);">Asigna un libro a un usuario</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Store" asp-controller="Loan" method="post">
                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label">Usuario</label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select">
                            <option value="">-- Selecciona un usuario --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="BookId" class="form-label">Libro</label>
                        <select asp-for="BookId" asp-items="ViewBag.Books" class="form-select">
                            <option value="">-- Selecciona un libro --</option>
                        </select>
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert-err p-3 mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Guardar préstamo
                        </button>
                        <a asp-action="Index" asp-controller="Loan" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>