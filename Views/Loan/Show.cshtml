@model LibrarySystem.Models.Loan
@{ ViewData["Title"] = "Loan Details"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="Loan" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Loans
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow" style="color:#ffb930;">03 — Loans</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Loan<br/>Details</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">Full record for this lending transaction.</p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <div class="detail-grid">
                <div class="dk">Member</div>
                <div class="dv">@Model.User.Name</div>
                <div class="dk">Phone</div>
                <div class="dv">@Model.User.Phone</div>
                <div class="dk">Book</div>
                <div class="dv">@Model.Book.Title</div>
                <div class="dk">Date</div>
                <div class="dv" style="font-family:'DM Mono',monospace; font-size:0.85rem; color:var(--sub);">@Model.CreatedAt?.ToString("yyyy-MM-dd")</div>
            </div>
            <div style="display:flex; gap:10px; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
                <a asp-action="Edit" asp-controller="Loan" asp-route-id="@Model.Id" class="btn-primary-custom" style="font-size:0.78rem; padding:8px 16px;">Edit record</a>
                <a asp-action="Index" asp-controller="Loan" class="btn-ghost-custom" style="font-size:0.78rem; padding:8px 16px;">Go back</a>
            </div>
        </div>
    </div>
</div>