@model LibrarySystem.Models.Book
@{ ViewData["Title"] = "Book Details"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="Book" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Catalog
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow">02 — Books</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Book<br/>Details</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">Full record for this title in the catalog.</p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <div class="detail-grid">
                <div class="dk">Title</div>
                <div class="dv">@Model.Title</div>
                <div class="dk">Author</div>
                <div class="dv">@Model.Author</div>
                <div class="dk">Status</div>
                <div class="dv">
                    @if (Model.Available)
                    {
                        <span class="badge-ok"><span class="badge-dot"></span>Available</span>
                    }
                    else
                    {
                        <span class="badge-no"><span class="badge-dot"></span>On loan</span>
                    }
                </div>
            </div>
            <div style="display:flex; gap:10px; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
                <a asp-action="Edit" asp-controller="Book" asp-route-id="@Model.Id" class="btn-primary-custom" style="font-size:0.78rem; padding:8px 16px;">Edit record</a>
                <a asp-action="Index" asp-controller="Book" class="btn-ghost-custom" style="font-size:0.78rem; padding:8px 16px;">Go back</a>
            </div>
        </div>
    </div>
</div>