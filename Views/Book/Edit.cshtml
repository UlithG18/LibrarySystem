@model LibrarySystem.Models.Book
@{ ViewData["Title"] = "Edit Book"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="Book" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Catalog
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow">02 — Books</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Edit book<br/>record.</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">
            Update the information for this title. Changes are saved immediately.
        </p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <form asp-action="Update" asp-controller="Book" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Title</label>
                        <input type="text" class="field-input" asp-for="Title" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Author</label>
                        <input type="text" class="field-input" asp-for="Author" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Available</label>
                        <input type="text" class="field-input" asp-for="Available" />
                    </div>
                    <div class="form-actions">
                        <button class="btn-primary-custom">Save changes</button>
                        <a asp-action="Index" asp-controller="Book" class="btn-ghost-custom">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>