@model LibrarySystem.Models.Book

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="Book" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-pencil me-2" style="color:#fbbf24;"></i>Editar libro</h4>
        <small style="color:var(--muted);">Modifica la información del libro en el catálogo</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Update" asp-controller="Book" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="form-label">Título</label>
                        <input type="text" class="form-control" asp-for="Title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Autor</label>
                        <input type="text" class="form-control" asp-for="Author" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Disponibilidad</label>
                        <input type="text" class="form-control" asp-for="Available" />
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Actualizar
                        </button>
                        <a asp-action="Index" asp-controller="Book" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>