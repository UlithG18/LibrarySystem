@model LibrarySystem.Models.Book

@{
    ViewData["Title"] = "Nuevo Libro";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="Book" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-plus-circle me-2" style="color:var(--accent);"></i>Agregar nuevo libro</h4>
        <small style="color:var(--muted);">Completa los datos para registrarlo en el catálogo</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Store" asp-controller="Book" method="post">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" type="text" placeholder="Ej: Cien años de soledad" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Autor</label>
                        <input asp-for="Author" type="text" class="form-control" placeholder="Ej: Gabriel García Márquez" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Available" class="form-label">Disponibilidad</label>
                        <input asp-for="Available" type="text" class="form-control" placeholder="true / false" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert-err p-3 mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Guardar libro
                        </button>
                        <a asp-action="Index" asp-controller="Book" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>