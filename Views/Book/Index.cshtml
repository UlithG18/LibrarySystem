@model IEnumerable<LibrarySystem.Models.Book>
@{ ViewData["Title"] = "Catalog"; }

<div class="pg-header">
    <div class="pg-header-left">
        <p class="pg-eyebrow">02 — Books</p>
        <h1 class="pg-title">Catalog</h1>
        <p class="pg-sub">All titles in the library collection</p>
    </div>
    <a asp-action="Create" asp-controller="Book" class="btn-primary-custom">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1v14M1 8h14"/></svg>
        Add book
    </a>
</div>

@if (TempData["message"] != null)
{
    <div class="alert-success-custom">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M2 8l4 4 8-8"/></svg>
        @TempData["message"]
    </div>
}

<div class="card-custom">
    <table class="stacks-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Author</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td class="td-id">#@book.Id</td>
                    <td class="td-main">@book.Title</td>
                    <td class="td-sub">@book.Author</td>
                    <td>
                        @if (book.Available)
                        {
                            <span class="badge-ok"><span class="badge-dot"></span>Available</span>
                        }
                        else
                        {
                            <span class="badge-no"><span class="badge-dot"></span>On loan</span>
                        }
                    </td>
                    <td>
                        <form asp-action="Destroy" asp-controller="Book" asp-route-id="@book.Id" method="post" style="display:inline;">
                            <a asp-action="Show" asp-controller="Book" asp-route-id="@book.Id" class="tbl-action" title="View">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 110-6 3 3 0 010 6z"/></svg>
                            </a>
                            <a asp-action="Edit" asp-controller="Book" asp-route-id="@book.Id" class="tbl-action" title="Edit" style="margin: 0 4px;">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M11.1 1.9a2 2 0 012.8 2.8L4.8 13.8 1 14.8l1-3.8z"/></svg>
                            </a>
                            <button type="submit" class="tbl-action danger" title="Delete">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 4h12M6 4V2h4v2M5 4v9h6V4"/></svg>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>