@model IEnumerable<LibrarySystem.Models.Book>

@{
    ViewData["Title"] = "Libros";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-book me-2" style="color:var(--accent);"></i>Catálogo de Libros</h4>
        <small style="color:var(--muted);">Administra el inventario de títulos disponibles</small>
    </div>
    <a asp-action="Create" asp-controller="Book" class="btn btn-accent">
        <i class="bi bi-plus-circle me-2"></i>Agregar libro
    </a>
</div>

@if (TempData["message"] != null)
{
    <div class="alert-ok p-3 mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>@TempData["message"]
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="padding-left:1.5rem;">ID</th>
                    <th>Título</th>
                    <th>Autor</th>
                    <th>Disponibilidad</th>
                    <th style="text-align:right; padding-right:1.5rem;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td style="padding-left:1.5rem; color:var(--muted); font-size:0.82rem;">#@book.Id</td>
                        <td class="fw-semibold">@book.Title</td>
                        <td style="color:var(--muted);">@book.Author</td>
                        <td>
                            @if (book.Available)
                            {
                                <span class="badge-avail"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Disponible</span>
                            }
                            else
                            {
                                <span class="badge-unavail"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>No disponible</span>
                            }
                        </td>
                        <td style="text-align:right; padding-right:1.5rem;">
                            <form asp-action="Destroy" asp-controller="Book" asp-route-id="@book.Id" method="post" class="d-inline">
                                <a asp-action="Show" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-icon me-1" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-icon me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="submit" class="btn btn-icon btn-icon-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>