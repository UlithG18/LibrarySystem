@model LibrarySystem.Models.User
@{ ViewData["Title"] = "Edit Member"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="User" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Members
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow" style="color:#00bfff;">01 — Members</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Edit member<br/>record.</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">
            Update contact details or other info for this member.
        </p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <form asp-action="Update" asp-controller="User" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Full name</label>
                        <input type="text" class="field-input" asp-for="Name" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Email</label>
                        <input type="text" class="field-input" asp-for="Email" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Phone</label>
                        <input type="text" class="field-input" asp-for="Phone" />
                    </div>
                    <div class="form-actions">
                        <button class="btn-primary-custom">Save changes</button>
                        <a asp-action="Index" asp-controller="User" class="btn-ghost-custom">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>