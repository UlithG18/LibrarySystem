@model LibrarySystem.Models.User

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="User" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-person-gear me-2" style="color:#fbbf24;"></i>Editar usuario</h4>
        <small style="color:var(--muted);">Actualiza la información del miembro</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Update" asp-controller="User" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="form-label">Nombre completo</label>
                        <input type="text" class="form-control" asp-for="Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="text" class="form-control" asp-for="Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" class="form-control" asp-for="Phone" />
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Actualizar
                        </button>
                        <a asp-action="Index" asp-controller="User" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>