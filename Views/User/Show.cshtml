@model LibrarySystem.Models.User

@{
    ViewData["Title"] = "Perfil del Usuario";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="User" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-person me-2" style="color:#60a5fa;"></i>Perfil del usuario</h4>
        <small style="color:var(--muted);">Datos del miembro registrado</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div style="width:64px; height:64px; border-radius:50%; background:rgba(59,130,246,0.12); display:inline-flex; align-items:center; justify-content:center; margin-bottom:0.75rem;">
                        <i class="bi bi-person" style="font-size:1.75rem; color:#60a5fa;"></i>
                    </div>
                    <h5 class="fw-bold mb-0">@Model.Name</h5>
                </div>
                <div style="display:grid; grid-template-columns: 110px 1fr; gap: 1rem 0.5rem; margin-bottom: 1.25rem;">
                    <span style="color:var(--muted); font-size:0.82rem; font-weight:600;">Nombre</span>
                    <span class="fw-semibold">@Model.Name</span>

                    <span style="color:var(--muted); font-size:0.82rem; font-weight:600;">Correo</span>
                    <span>@Model.Email</span>

                    <span style="color:var(--muted); font-size:0.82rem; font-weight:600;">Teléfono</span>
                    <span>@Model.Phone</span>
                </div>
                <hr style="border-color:var(--border);" />
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-controller="User" asp-route-id="@Model.Id" class="btn btn-accent btn-sm">
                        <i class="bi bi-pencil me-1"></i>Editar
                    </a>
                    <a asp-action="Index" asp-controller="User" class="btn btn-ghost btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>