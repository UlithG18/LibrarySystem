@model IEnumerable<LibrarySystem.Models.User>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-people me-2" style="color:#60a5fa;"></i>Usuarios</h4>
        <small style="color:var(--muted);">Miembros registrados en la biblioteca</small>
    </div>
    <a asp-action="Create" asp-controller="User" class="btn btn-accent">
        <i class="bi bi-person-plus me-2"></i>Nuevo usuario
    </a>
</div>

@if (TempData["message"] != null)
{
    <div class="alert-ok p-3 mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>@TempData["message"]
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="padding-left:1.5rem;">ID</th>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th style="text-align:right; padding-right:1.5rem;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td style="padding-left:1.5rem; color:var(--muted); font-size:0.82rem;">#@user.Id</td>
                        <td class="fw-semibold">@user.Name</td>
                        <td style="color:var(--muted);">@user.Email</td>
                        <td style="color:var(--muted);">@user.Phone</td>
                        <td style="text-align:right; padding-right:1.5rem;">
                            <form asp-action="Destroy" asp-controller="User" asp-route-id="@user.Id" method="post" class="d-inline">
                                <a asp-action="Show" asp-controller="User" asp-route-id="@user.Id" class="btn btn-icon me-1" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-controller="User" asp-route-id="@user.Id" class="btn btn-icon me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="submit" class="btn btn-icon btn-icon-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>