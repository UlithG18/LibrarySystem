@model IEnumerable<LibrarySystem.Models.User>
@{ ViewData["Title"] = "Members"; }

<div class="pg-header">
    <div class="pg-header-left">
        <p class="pg-eyebrow" style="color:#00bfff;">01 — Members</p>
        <h1 class="pg-title">Members</h1>
        <p class="pg-sub">All registered library members</p>
    </div>
    <a asp-action="Create" asp-controller="User" class="btn-primary-custom">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1v14M1 8h14"/></svg>
        Add member
    </a>
</div>

@if (TempData["message"] != null)
{
    <div class="alert-success-custom">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M2 8l4 4 8-8"/></svg>
        @TempData["message"]
    </div>
}

<div class="card-custom">
    <table class="stacks-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="td-id">#@user.Id</td>
                    <td class="td-main">@user.Name</td>
                    <td class="td-sub">@user.Email</td>
                    <td class="td-sub">@user.Phone</td>
                    <td>
                        <form asp-action="Destroy" asp-controller="User" asp-route-id="@user.Id" method="post" style="display:inline;">
                            <a asp-action="Show" asp-controller="User" asp-route-id="@user.Id" class="tbl-action" title="View">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 110-6 3 3 0 010 6z"/></svg>
                            </a>
                            <a asp-action="Edit" asp-controller="User" asp-route-id="@user.Id" class="tbl-action" title="Edit" style="margin: 0 4px;">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M11.1 1.9a2 2 0 012.8 2.8L4.8 13.8 1 14.8l1-3.8z"/></svg>
                            </a>
                            <button type="submit" class="tbl-action danger" title="Delete">
                                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 4h12M6 4V2h4v2M5 4v9h6V4"/></svg>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>