@model LibrarySystem.Models.User

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="User" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0" style="font-size:1.1rem;"><i class="bi bi-person-plus me-2" style="color:var(--accent);"></i>Registrar usuario</h4>
        <small style="color:var(--muted);">Agrega un nuevo miembro a la biblioteca</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Store" asp-controller="User" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre completo</label>
                        <input asp-for="Name" class="form-control" type="text" placeholder="Ej: María Fernanda López" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo electrónico</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Teléfono</label>
                        <input asp-for="Phone" type="text" class="form-control" placeholder="300 123 4567" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert-err p-3 mb-3 d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="bi bi-floppy me-2"></i>Registrar
                        </button>
                        <a asp-action="Index" asp-controller="User" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>