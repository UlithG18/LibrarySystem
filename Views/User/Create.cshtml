@model LibrarySystem.Models.User
@{ ViewData["Title"] = "Add Member"; }

<div style="margin-bottom: 2rem;">
    <a asp-action="Index" asp-controller="User" class="btn-back">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10 3L5 8l5 5"/></svg>
        Back to Members
    </a>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
    <div>
        <p class="pg-eyebrow" style="color:#00bfff;">01 — Members</p>
        <h1 class="pg-title" style="font-size:2.5rem; margin-bottom:0.75rem;">Register a<br/>new member.</h1>
        <p style="color:var(--sub); font-size:0.88rem; line-height:1.6;">
            Add a new member to the library. They'll be able to borrow books once registered.
        </p>
    </div>

    <div class="card-custom">
        <div class="card-custom-body">
            <form asp-action="Store" asp-controller="User" method="post">
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label" asp-for="Name">Full name</label>
                        <input asp-for="Name" class="field-input" type="text" placeholder="e.g. María Fernanda López" />
                    </div>
                    <div class="field-group">
                        <label class="field-label" asp-for="Email">Email</label>
                        <input asp-for="Email" type="email" class="field-input" placeholder="name@example.com" />
                    </div>
                    <div class="field-group">
                        <label class="field-label" asp-for="Phone">Phone</label>
                        <input asp-for="Phone" type="text" class="field-input" placeholder="300 123 4567" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert-error-custom">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2L1 14h14zM8 6v4M8 12v1"/></svg>
                            @TempData["message"]
                        </div>
                    }

                    <div class="form-actions">
                        <button type="submit" class="btn-primary-custom">Register member</button>
                        <a asp-action="Index" asp-controller="User" class="btn-ghost-custom">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>