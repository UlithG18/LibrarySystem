@{
    ViewData["Title"] = "Panel Principal";
}

<div style="background: linear-gradient(135deg, #064e3b, #0f1117); border: 1px solid #065f46; border-radius: 14px; padding: 2.5rem; margin-bottom: 2rem;">
    <div class="row align-items-center">
        <div class="col-md-8">
            <p class="mb-1" style="color:#34d399; font-size:0.8rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;">Bienvenido</p>
            <h1 class="fw-bold mb-2" style="font-size:2rem; color:#fff;">Sistema de Biblioteca</h1>
            <p class="mb-4" style="color:#9ca3af; font-size:1rem; max-width:480px;">
                Administra usuarios, libros y préstamos desde un solo lugar. Rápido, simple y sin complicaciones.
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Loan" asp-action="Create" class="btn btn-accent px-4">
                    <i class="bi bi-plus-circle me-2"></i>Registrar préstamo
                </a>
                <a asp-controller="Book" asp-action="Index" class="btn btn-ghost px-4" style="color:#9ca3af;">
                    <i class="bi bi-book me-2"></i>Ver catálogo
                </a>
            </div>
        </div>
        <div class="col-md-4 text-end d-none d-md-block">
            <i class="bi bi-building" style="font-size: 7rem; color: rgba(16,185,129,0.15);"></i>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="background:rgba(59,130,246,0.12); border-radius:10px; padding:0.85rem;">
                    <i class="bi bi-people" style="font-size:1.5rem; color:#60a5fa;"></i>
                </div>
                <div>
                    <p style="font-size:0.72rem; color:var(--muted); text-transform:uppercase; font-weight:700; margin:0;">Usuarios registrados</p>
                    <p class="fw-bold mb-0" style="font-size:1.1rem;">Gestión de miembros</p>
                </div>
            </div>
            <div style="padding: 0 1.5rem 1.25rem;">
                <a asp-controller="User" asp-action="Index" class="btn btn-ghost w-100" style="font-size:0.82rem;">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Usuarios
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="background:var(--accent-dim); border-radius:10px; padding:0.85rem;">
                    <i class="bi bi-book" style="font-size:1.5rem; color:var(--accent);"></i>
                </div>
                <div>
                    <p style="font-size:0.72rem; color:var(--muted); text-transform:uppercase; font-weight:700; margin:0;">Catálogo de libros</p>
                    <p class="fw-bold mb-0" style="font-size:1.1rem;">Inventario completo</p>
                </div>
            </div>
            <div style="padding: 0 1.5rem 1.25rem;">
                <a asp-controller="Book" asp-action="Index" class="btn btn-accent w-100" style="font-size:0.82rem;">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Libros
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="background:rgba(245,158,11,0.12); border-radius:10px; padding:0.85rem;">
                    <i class="bi bi-arrow-left-right" style="font-size:1.5rem; color:#fbbf24;"></i>
                </div>
                <div>
                    <p style="font-size:0.72rem; color:var(--muted); text-transform:uppercase; font-weight:700; margin:0;">Préstamos activos</p>
                    <p class="fw-bold mb-0" style="font-size:1.1rem;">Control de salidas</p>
                </div>
            </div>
            <div style="padding: 0 1.5rem 1.25rem;">
                <a asp-controller="Loan" asp-action="Index" class="btn btn-ghost w-100" style="font-size:0.82rem;">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Préstamos
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="fw-bold mb-3" style="font-size:0.95rem;">
            <i class="bi bi-info-circle me-2" style="color:var(--accent);"></i>¿Qué puedes hacer aquí?
        </h5>
        <div class="row g-4">
            <div class="col-md-4">
                <h6 class="fw-bold" style="font-size:0.85rem;"><i class="bi bi-person-check me-2" style="color:#60a5fa;"></i>Gestión de usuarios</h6>
                <p style="color:var(--muted); font-size:0.82rem; margin:0;">Registra y administra los miembros de tu biblioteca. Consulta su historial de préstamos y datos de contacto fácilmente.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold" style="font-size:0.85rem;"><i class="bi bi-bookmark-check me-2" style="color:var(--accent);"></i>Catálogo de libros</h6>
                <p style="color:var(--muted); font-size:0.82rem; margin:0;">Mantén un inventario actualizado de todos los títulos. Controla qué libros están disponibles para préstamo en tiempo real.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold" style="font-size:0.85rem;"><i class="bi bi-clock-history me-2" style="color:#fbbf24;"></i>Seguimiento de préstamos</h6>
                <p style="color:var(--muted); font-size:0.82rem; margin:0;">Registra cada préstamo con usuario, libro y fecha. El sistema evita duplicados para que cada copia quede siempre bien contabilizada.</p>
            </div>
        </div>
    </div>
</div>