@{
    ViewData["Title"] = "Overview";
}

<div style="margin-bottom: 3rem;">
    <p style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#00e5a0; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.5rem;">Library Management</p>
    <h1 style="font-family:'Syne',sans-serif; font-size:3.5rem; font-weight:800; line-height:0.95; letter-spacing:-2px; color:#eef0f6; margin-bottom:1rem;">
        Everything<br/>in one place.
    </h1>
    <p style="color:#7b85a0; font-size:1rem; max-width:420px; line-height:1.6;">
        Manage your library's members, book catalog, and loan records from a single, focused interface.
    </p>
</div>

<!-- Quick actions row -->
<div style="display:flex; gap:12px; margin-bottom:3.5rem; flex-wrap:wrap;">
    <a asp-controller="Loan" asp-action="Create" class="btn-primary-custom">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1v14M1 8h14"/></svg>
        New Loan
    </a>
    <a asp-controller="Book" asp-action="Create" class="btn-ghost-custom">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1v14M1 8h14"/></svg>
        Add Book
    </a>
    <a asp-controller="User" asp-action="Create" class="btn-ghost-custom">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1v14M1 8h14"/></svg>
        Register Member
    </a>
</div>

<!-- Three module cards -->
<div style="display:grid; grid-template-columns: repeat(3,1fr); gap:1px; background:var(--border); border-radius:16px; overflow:hidden; border:1px solid var(--border);">

    <a asp-controller="User" asp-action="Index" style="text-decoration:none; background:var(--surface); padding:2rem; display:block; transition:background .15s;" onmouseover="this.style.background='var(--panel)'" onmouseout="this.style.background='var(--surface)'">
        <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#00bfff; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:1.5rem;">01 — Members</div>
        <div style="font-family:'Syne',sans-serif; font-size:1.6rem; font-weight:800; color:#eef0f6; letter-spacing:-0.5px; margin-bottom:0.75rem; line-height:1.1;">Member<br/>Registry</div>
        <p style="color:#7b85a0; font-size:0.83rem; line-height:1.55; margin-bottom:1.5rem;">Register and manage all library members. Track contact details and lending history.</p>
        <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#00bfff; letter-spacing:0.06em;">View all →</span>
    </a>

    <a asp-controller="Book" asp-action="Index" style="text-decoration:none; background:var(--surface); padding:2rem; display:block; transition:background .15s;" onmouseover="this.style.background='var(--panel)'" onmouseout="this.style.background='var(--surface)'">
        <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#00e5a0; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:1.5rem;">02 — Books</div>
        <div style="font-family:'Syne',sans-serif; font-size:1.6rem; font-weight:800; color:#eef0f6; letter-spacing:-0.5px; margin-bottom:0.75rem; line-height:1.1;">Book<br/>Catalog</div>
        <p style="color:#7b85a0; font-size:0.83rem; line-height:1.55; margin-bottom:1.5rem;">Maintain a full inventory of titles. See real-time availability for every book in your collection.</p>
        <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#00e5a0; letter-spacing:0.06em;">View all →</span>
    </a>

    <a asp-controller="Loan" asp-action="Index" style="text-decoration:none; background:var(--surface); padding:2rem; display:block; transition:background .15s;" onmouseover="this.style.background='var(--panel)'" onmouseout="this.style.background='var(--surface)'">
        <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#ffb930; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:1.5rem;">03 — Loans</div>
        <div style="font-family:'Syne',sans-serif; font-size:1.6rem; font-weight:800; color:#eef0f6; letter-spacing:-0.5px; margin-bottom:0.75rem; line-height:1.1;">Loan<br/>Tracking</div>
        <p style="color:#7b85a0; font-size:0.83rem; line-height:1.55; margin-bottom:1.5rem;">Record every loan by member and book. The system prevents duplicates and keeps your data clean.</p>
        <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#ffb930; letter-spacing:0.06em;">View all →</span>
    </a>

</div>